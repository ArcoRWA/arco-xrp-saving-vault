{
  "name": "arco-xrp-saving-vault",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "XRPL testnet backend for the Arco XRP Saving Vault MVP.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:validate": "prisma validate",
    "start": "node dist/server.js",
    "worker": "node dist/worker.js"
  },
  "dependencies": {
    "@fastify/sensible": "^6.0.3",
    "@prisma/client": "^6.19.0",
    "decimal.js": "^10.6.0",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.2",
    "xrpl": "^4.4.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "prisma": "^6.19.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.13"
  }
}
